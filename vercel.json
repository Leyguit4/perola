{
  "routes": [
    { "src": "/api/user/(?<userId>[^/]+)", "dest": "/api/user/[userId].js" },
    { "src": "/api/submit", "dest": "/api/submit.js" },
    { "src": "/perola/form/midia/(?<userId>\\d+)", "dest": "/index.html" },
    { "src": "/perola/form/midia", "dest": "/index.html" },
    { "src": "/perola/form", "dest": "/index.html" },
    { "src": "/perola", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
